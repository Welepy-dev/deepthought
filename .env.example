# Postgres (docker-compose service)
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=transcendence

# Prisma connection string (host "postgres" inside docker network)
DATABASE_URL=postgresql://your_db_user:your_db_password@postgres:5432/transcendence

# JWT signing secrets (generate long random strings)
JWT_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret

# Public URL of the frontend (OAuth redirects land here)
FRONTEND_URL=https://localhost:8443

# Extra CORS origins, comma-separated (the https nginx origin, ngrok, etc.)
CORS_ORIGINS=https://localhost:8443

# 42 intra OAuth application credentials — the callback below must exactly
# match the redirect URI registered on your 42 intra app dashboard.
FORTY_TWO_CLIENT_ID=your_42_client_id
FORTY_TWO_CLIENT_SECRET=your_42_client_secret
FORTY_TWO_CALLBACK_URL=https://localhost:8443/api/auth/42/callback

# SMTP account used to send OTP emails
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_app_password

# Origin the browser uses for the API/sockets/uploads, once fronted by nginx (make certs && make up)
VITE_SERVER_ORIGIN=https://localhost:8443
